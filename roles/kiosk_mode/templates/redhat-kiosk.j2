#!/bin/sh

kiosk_page="http://localhost:{{ kiosk_port }}"

while true; do
	/usr/bin/curl -o /dev/null $kiosk_page 2> /dev/null
	rc=$?

	if [ "$rc" == "0" ]; then
{% if ansible_facts['distribution_major_version'] | int >= 9 %}
		/usr/bin/firefox --kiosk "$kiosk_page"
{% else %}
		/usr/bin/firefox --kiosk "$kiosk_page" --display=:0
{% endif %}
	else
		sleep 1
	fi
done
